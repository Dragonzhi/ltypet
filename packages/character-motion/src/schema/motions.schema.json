{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ltypet.example.com/schemas/motions.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rigId", "clips"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rigId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "clips": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "fps",
          "durationFrames",
          "loop",
          "tracks",
          "events"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "fps": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "durationFrames": {
            "type": "integer",
            "minimum": 1
          },
          "loop": {
            "enum": ["none", "repeat"]
          },
          "tracks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["partId", "keyframes"],
              "properties": {
                "partId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
                "keyframes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["frame", "values"],
                    "properties": {
                      "frame": { "type": "integer", "minimum": 0 },
                      "values": {
                        "type": "object",
                        "additionalProperties": false,
                        "minProperties": 1,
                        "properties": {
                          "x": { "type": "number", "minimum": -10000, "maximum": 10000 },
                          "y": { "type": "number", "minimum": -10000, "maximum": 10000 },
                          "rotation": { "type": "number", "minimum": -36000, "maximum": 36000 },
                          "scaleX": { "type": "number", "minimum": 0.01, "maximum": 100 },
                          "scaleY": { "type": "number", "minimum": 0.01, "maximum": 100 },
                          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
                          "renderSlot": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" }
                        }
                      },
                      "easing": {
                        "oneOf": [
                          { "enum": ["linear", "easeIn", "easeOut", "easeInOut"] },
                          {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["cubicBezier"],
                            "properties": {
                              "cubicBezier": {
                                "type": "array",
                                "prefixItems": [
                                  { "type": "number", "minimum": 0, "maximum": 1 },
                                  { "type": "number" },
                                  { "type": "number", "minimum": 0, "maximum": 1 },
                                  { "type": "number" }
                                ],
                                "minItems": 4,
                                "maxItems": 4,
                                "items": false
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["frame", "type"],
              "properties": {
                "frame": { "type": "integer", "minimum": 0 },
                "type": {
                  "enum": [
                    "blink",
                    "mouthOpen",
                    "mouthClose",
                    "sfx",
                    "custom"
                  ]
                },
                "payload": {
                  "type": "object",
                  "additionalProperties": {
                    "anyOf": [
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" }
                    ]
                  }
                }
              }
            }
          },
          "suppressProceduralChannels": {
            "type": "array",
            "items": {
              "enum": [
                "breathing",
                "blinking",
                "pointer-follow",
                "hair-physics",
                "ear-twitch"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
